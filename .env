# =========================================
# 🧠 SUPPORTBOT LITE - Environment Variables
# =========================================

# --- DATABASE CONFIG ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=supportbot
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy connection string (used by FastAPI)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/supportbot

# --- EMBEDDING MODEL CONFIG ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- LLM CONFIG (LLaMA3 via Ollama) ---
LLAMA3_URL=http://host.docker.internal:11434/api/generate
LLAMA3_MODEL=llama3

# --- APP SETTINGS ---
SIMILARITY_THRESHOLD=0.75
ENV=development
